# Copy to .env (git-ignored) and fill in. Auto-loaded by `python -m evals.run_eval`
# when python-dotenv is installed (part of the `openrouter` / `dev` extras).

# ---- OpenRouter (recommended for the LLM arms) ----------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Any OpenRouter model id. Overrides the canonical-name mapping when set.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional; defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers OpenRouter uses for rankings.
OPENROUTER_SITE_URL=https://github.com/sheldon904/claims-audit-agent
OPENROUTER_APP_NAME=claims-audit-agent

# Force a provider regardless of which keys are present: anthropic | openrouter
# LLM_PROVIDER=openrouter

# ---- Native Anthropic (alternative backend) -------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
