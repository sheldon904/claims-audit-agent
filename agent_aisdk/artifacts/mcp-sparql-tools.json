              "maxLength": 10000,
              "description": "SPARQL query string (SELECT or ASK)."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Optional hard cap on returned bindings (default 200)."
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        }
      }
    },
    {
      "name": "sparql_ask",
      "description": "Convenience wrapper for SPARQL ASK — returns a plain {boolean: true|false}. Use when the agent just needs a yes/no check without parsing bindings.",
      "inputSchema": {
        "jsonSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "maxLength": 10000
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        }
      }
    },
    {
      "name": "list_graphs",
      "description": "Enumerate the named graphs currently present in the store with their approximate triple counts. Useful for exploring what data is available.",
      "inputSchema": {
        "jsonSchema": {
          "type": "object",
