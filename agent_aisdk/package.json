{
  "name": "claims-audit-agent-aisdk",
  "version": "0.1.0",
  "private": true,
  "description": "Third orchestration arm of claims-audit-agent: a medical-claims line-item auditor on the Vercel AI SDK (@ai-sdk/anthropic), benchmarked by the repo's canonical Python eval harness.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "claims-audit-aisdk": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "audit": "node dist/cli.js",
    "audit:dev": "tsx src/cli.ts",
    "mcp:probe": "tsx scripts/mcp_probe.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.18",
    "@ai-sdk/mcp": "2.0.16",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ai": "7.0.35",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "22.20.1",
    "eslint": "9.39.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
